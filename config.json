{
	"$schema": "https://raw.githubusercontent.com/Bedrock-OSS/regolith-schemas/main/config/v1.7.json",
	"author": "MACHINE_BUILDER",
	"name": "Backrooms_mb",
	"packs": {
		"behaviorPack": "./packs/BP",
		"resourcePack": "./packs/RP"
	},
	"regolith": {
		"dataPath": "./packs/data",
		"filterDefinitions": {
			"gametests": {
				"url": "github.com/Bedrock-OSS/regolith-filters",
				"version": "1.7.4"
			}
		},
		"formatVersion": "1.7.0",
		"profiles": {
			"default": {
				"export": {
					"build": "standard",
					"readOnly": false,
					"target": "development"
				},
				"filters": [
                    {
                        "filter": "gametests",
                        "settings": {
                            "buildOptions": {
                                "minify": false
                            },
                            "modules": [
                                "@minecraft/server@2.8.0-beta"
                            ],
                            "outfile": "BP/scripts/main.js"
                        }
                    }
				]
			}
		}
	}
}